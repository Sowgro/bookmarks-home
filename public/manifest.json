{
  "manifest_version": 3,
  "name": "Bookmarks Home",
  "version": "1.1",
  "description": "A customizable new tab page displaying the users bookmarks",
  "chrome_url_overrides" : {
    "newtab": "index.html"
  },
  "chrome_settings_overrides": {
    "homepage": "index.html"
  },
  "icons": {
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [{
    "js": ["iconGrabber.js"],
    "matches": ["<all_urls>"]
  }],
  "browser_specific_settings": {
    "gecko": {
      "id": "bookmarks-home@sowgro.net",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "58.0"
    }
  }
}
